APP_NAME=Graph Query API
APP_ENV=dev
CORS_ORIGINS=http://localhost:5173
# Relative paths resolve to repo root (not process cwd); override with absolute paths if needed.
DATA_DIR=./data
DATA_ENTITY_DIR=./sap-o2c-data
SCHEMA_DICTIONARY_PATH=./backend/app/prompts/schema_dictionary.json
GUARDRAIL_POLICY_PATH=./backend/app/prompts/guardrail_policy.md
LLM_PROVIDER=gemini
# Use any model id from ListModels that supports generateContent (names change over time).
LLM_API_KEY=your-google-ai-api-key
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.1
VITE_API_BASE=http://localhost:8000
